# Copy to `.env` (git-ignored) and fill in. Used by Fastlane / CI.
# Prefer an App Store Connect API key over Apple ID — it avoids 2FA in CI.

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_API_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8

# Used by fastlane/Appfile
ASC_APPLE_ID=you@example.com
APPLE_TEAM_ID=XXXXXXXXXX
